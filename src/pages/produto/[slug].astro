---
import BaseLayout from "../BaseLayout.astro";
import CartDrawer from "../../components/CartDrawer.astro";
import { products } from "../../data/products";
import SpeedInsights from "@vercel/speed-insights/astro";

export async function getStaticPaths() {
    return products
        .filter((p) => p.slug)
        .map((product) => ({
            params: { slug: product.slug },
            props: { product },
        }));
}

const { product } = Astro.props;

if (!product) {
    return Astro.redirect("/404");
}

const siteUrl = "https://trendsbrindes.com.br";
const canonicalUrl = `${siteUrl}/produto/${product.slug}`;
const pageTitle = `${product.name} | Trends Brindes`;
const pageDescription = product.description.substring(0, 160);
const mainImage = product.image || "/placeholder-product.png";

const jsonLd = {
    "@context": "https://schema.org/",
    "@type": "Product",
    name: product.name,
    image: mainImage,
    description: product.description,
    sku: product.code,
    mpn: product.code,
    brand: {
        "@type": "Brand",
        name: "Trends Brindes",
    },
    offers: {
        "@type": "Offer",
        url: canonicalUrl,
        priceCurrency: "BRL",
        availability: "https://schema.org/InStock",
        seller: {
            "@type": "Organization",
            name: "Trends Brindes",
        },
    },
    category: product.category,
};

const hasDimensions =
    product.dimensions &&
    Object.values(product.dimensions).some(
        (v) => v !== null && v !== undefined,
    );

const dimensionLabels: Record<string, string> = {
    height: "Altura",
    width: "Largura",
    depth: "Profundidade",
    diameter: "Diâmetro",
    circumference: "Circunferência",
    length: "Comprimento",
    thickness: "Espessura",
};
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    permalink={canonicalUrl}
    ogImage={mainImage}
>
    <link rel="canonical" href={canonicalUrl} slot="head" />
    <meta property="og:type" content="product" slot="head" />
    <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(jsonLd)}
        slot="head"
    />

    <main>
        <SpeedInsights />

        <article class="py-10 md:py-16 px-4">
            <div class="max-w-6xl mx-auto">
                <nav aria-label="Breadcrumb" class="mb-8">
                    <a
                        href="/"
                        class="inline-flex items-center text-sm font-bold text-emerald-800 transition-colors hover:text-amber-600"
                    >
                        ← Voltar para o início
                    </a>
                </nav>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-start"
                >
                    <section class="space-y-6">
                        <div
                            class="product-gallery overflow-hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-xl shadow-slate-200/70"
                        >
                            <img
                                id="main-image"
                                src={mainImage}
                                alt={`Foto de ${product.name}`}
                                class="h-[22rem] w-full rounded-xl bg-slate-50 object-contain sm:h-[30rem]"
                                loading="eager"
                            />
                        </div>

                        {
                            product.colors && product.colors.length > 0 && (
                                <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                                    <h3 class="mb-4 text-lg font-bold text-slate-950">
                                        Cores Disponíveis
                                    </h3>
                                    <div
                                        id="colors-container"
                                        class="flex flex-wrap gap-4"
                                    >
                                        {product.colors.map((color) => (
                                            <button
                                                type="button"
                                                class="color-option h-12 w-12 rounded-xl border-2 border-slate-200 transition-all shadow-sm focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/20 active:scale-95"
                                                style={`background-color: ${color.hex}`}
                                                title={color.name}
                                                aria-label={`Cor ${color.name}`}
                                                data-color-name={color.name}
                                            />
                                        ))}
                                    </div>
                                    <p
                                        id="selected-color-text"
                                        class="mt-3 text-sm font-medium text-slate-500 min-h-[20px]"
                                    />
                                </div>
                            )
                        }
                    </section>

                    <section>
                        <div
                            class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/70 md:p-8"
                        >
                            <header class="mb-6">
                                <span
                                    class="inline-flex rounded-full bg-amber-50 px-4 py-2 text-sm font-bold text-amber-700 mb-4"
                                >
                                    Código: {product.code}
                                </span>
                                <h1
                                    class="font-bold text-slate-950 mb-4 text-4xl lg:text-5xl leading-tight"
                                >
                                    {product.name}
                                </h1>
                            </header>

                            <div class="space-y-6">
                                <div>
                                    <h3
                                        class="text-sm font-bold uppercase tracking-wide text-slate-500 mb-2"
                                    >
                                        Descrição
                                    </h3>
                                    <p
                                        class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-lg leading-relaxed text-slate-700"
                                    >
                                        {product.description}
                                    </p>
                                </div>

                                <div class="grid grid-cols-2 gap-4">
                                    <div
                                        class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5"
                                    >
                                        <h3
                                            class="mb-1 text-xs font-bold uppercase tracking-wide text-emerald-700"
                                        >
                                            Disponibilidade
                                        </h3>
                                        <p
                                            class="text-lg font-bold text-emerald-950"
                                        >
                                            Sob Consulta
                                        </p>
                                    </div>
                                    <div
                                        class="rounded-2xl border border-slate-100 bg-slate-50 p-5"
                                    >
                                        <h3
                                            class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-600"
                                        >
                                            Categoria
                                        </h3>
                                        <p
                                            class="text-lg font-bold text-slate-900"
                                        >
                                            {product.category}
                                        </p>
                                    </div>
                                </div>

                                {
                                    hasDimensions && (
                                        <div class="rounded-2xl border border-slate-200 bg-white p-5">
                                            <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500 mb-3">
                                                Dimensões do Produto
                                            </h3>
                                            <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                                                {Object.entries(
                                                    product.dimensions!,
                                                ).map(
                                                    ([key, value]) =>
                                                        value && (
                                                            <div class="flex justify-start gap-1 border-b border-slate-100 pb-1">
                                                                <dt class="text-slate-500 font-medium">
                                                                    {dimensionLabels[
                                                                        key
                                                                    ] || key}
                                                                    :
                                                                </dt>
                                                                <dd class="text-slate-900 font-semibold">
                                                                    {value}
                                                                </dd>
                                                            </div>
                                                        ),
                                                )}
                                            </dl>
                                        </div>
                                    )
                                }

                                <button
                                    id="add-to-cart-btn"
                                    data-product-id={product.id}
                                    data-product-name={product.name}
                                    data-product-code={product.code}
                                    data-product-category={product.category}
                                    class="flex w-full items-center justify-center gap-3 rounded-xl bg-[#065F46] py-4 text-lg font-bold text-white shadow-lg shadow-emerald-900/20 transition-all hover:-translate-y-0.5 hover:bg-[#047857] active:scale-[0.98] outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#065F46]"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                        ><circle cx="8" cy="21" r="1"
                                        ></circle><circle cx="19" cy="21" r="1"
                                        ></circle><path
                                            d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"
                                        ></path></svg
                                    >
                                    <span id="btn-label"
                                        >Adicionar ao Carrinho</span
                                    >
                                </button>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </article>

        <a
            href={`https://wa.me/5551984502907?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20o%20produto%20${encodeURIComponent(product.name)}%20(Cód:%20${product.code})`}
            target="_blank"
            rel="noopener noreferrer"
            class="fixed bottom-6 right-6 flex items-center justify-center transition-all z-30 hover:scale-110 focus:outline-none focus:ring-4 focus:ring-emerald-500/50 rounded-full"
            aria-label="Conversar via WhatsApp"
        >
            <img src="/whatsapp.png" alt="" class="w-14 h-14" />
        </a>

        <CartDrawer />
    </main>
</BaseLayout>

<style>
    .color-option:hover {
        transform: scale(1.1);
    }

    .color-option.is-selected {
        transform: scale(1.1);
        @apply border-amber-500 ring-4 ring-amber-500/15;
    }
</style>

<script>
    import { addToCart } from "../../scripts/cartStore";

    let selectedColorName = "";
    const colorButtons = document.querySelectorAll(".color-option");
    const selectedColorText = document.getElementById("selected-color-text");
    const addToCartBtn = document.getElementById(
        "add-to-cart-btn",
    ) as HTMLButtonElement;
    const btnLabel = document.getElementById("btn-label");
    const mainImage = document.getElementById("main-image") as HTMLImageElement;

    colorButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            selectedColorName = target.dataset.colorName || "";

            colorButtons.forEach((b) => b.classList.remove("is-selected"));
            target.classList.add("is-selected");

            if (selectedColorText) {
                selectedColorText.textContent = `Cor selecionada: ${selectedColorName}`;
            }
        });
    });

    addToCartBtn?.addEventListener("click", () => {
        const { productId, productName, productCode, productCategory } =
            addToCartBtn.dataset;

        const item = {
            id: parseInt(productId || "0"),
            nome: productName,
            codigo: productCode,
            categoria: productCategory,
            imagem: mainImage?.src || "",
            corSelecionada: selectedColorName,
        };

        addToCart(item);

        if (btnLabel) {
            const originalText = btnLabel.textContent;
            btnLabel.textContent = "Adicionado!";
            addToCartBtn.classList.replace("bg-[#065F46]", "bg-emerald-600");

            setTimeout(() => {
                btnLabel.textContent = originalText;
                addToCartBtn.classList.replace(
                    "bg-emerald-600",
                    "bg-[#065F46]",
                );
            }, 2000);
        }
    });
</script>
