---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta
            name="description"
            content="Brindes personalizados premium em Porto Alegre. Garrafas térmicas, squeezes, mochilas e gravação a laser com entrega rápida para todo o RS."
        />
        <meta
            name="keywords"
            content="brindes personalizados porto alegre, brindes corporativos premium, gravação a laser, garrafa térmica personalizada, trends brindes, bolsas"
        />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta
            property="og:url"
            content="https://trends-eta-three.vercel.app/"
        />
        <meta
            property="og:image"
            content="https://trends-eta-three.vercel.app/og-image.jpg"
        />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:type" content="website" />
        <meta
            property="og:logo"
            content="https://trends-eta-three.vercel.app/logo.png"
        />

        <meta name="twitter:card" content="summary_large_image" />
        <meta
            name="twitter:title"
            content="Trends Brindes - Brindes Premium Personalizados"
        />
        <meta
            name="twitter:description"
            content="Destaque sua marca com brindes corporativos premium. Garrafas térmicas, squeezes e mochilas com gravação a laser. Entrega rápida no RS."
        />
        <meta
            name="twitter:image"
            content="https://trends-eta-three.vercel.app/og-image.jpg"
        />

        <link rel="icon" type="image/png" href="/logo.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            />
        </noscript>
        <style is:global>
            @tailwind base;
            @tailwind components;
            @tailwind utilities;

            :root {
                --brand: #065f46;
                --brand-hover: #047857;
                --accent: #f59e0b;
                --accent-hover: #d97706;
                --surface: #f8fafc;
                --text: #0f172a;
                --muted: #475569;
                --border: #e2e8f0;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                color: var(--text);
                background:
                    radial-gradient(
                        circle at top left,
                        rgba(245, 158, 11, 0.1),
                        transparent 28rem
                    ),
                    var(--surface);
            }
        </style>
    </head>
    <body style="font-family: Plus Jakarta Sans, sans-serif;">
        <div
            class="bg-emerald-950 text-white py-3 px-4 text-center text-sm font-semibold tracking-wide"
        >
            🌾 ORGULHO DE SER GAÚCHA: PRODUÇÃO E LOGÍSTICA RÁPIDA PARA TODO O
            RIO GRANDE DO SUL 🌾
        </div>
        <Header />
        <slot />
        <Footer />
    </body>
</html>

<style is:global></style>
