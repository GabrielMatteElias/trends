            let activeCategory = "all";
            let searchQuery = "";
            let filterTransition;

            function renderFeaturedProducts() {
                const selectedProducts = products.slice(0, 10);
                const topProducts = selectedProducts.slice(0, 5);
                const bottomProducts = selectedProducts.slice(5);
                const makeLoop = (items) => [...items, ...items, ...items, ...items];
                const renderCard = (product) => `
                    <a href="/product?id=${product.id}" class="featured-card group block overflow-hidden focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/25" aria-label="Ver detalhes de ${product.name}">
                        <div class="aspect-[1/1] overflow-hidden flex items-center justify-center p-4">
                            <img
                                src="${product.image}"
                                alt="${product.name}"
                                loading="lazy"
                                decoding="async"
                                class="featured-card-image h-[85%] w-[85%] object-contain transition-transform duration-500 group-hover:scale-[1.03]"
                            />
                        </div>
                        <div class="px-3 pb-4 pt-2 text-center">
                            <h3 class="text-sm font-semibold tracking-tight text-slate-800">${product.name}</h3>
                            <p class="mt-1 text-[11px] font-medium text-slate-400 uppercase tracking-wider">${product.category}</p>
                        </div>
                    </a>
                `;

                document.getElementById("featured-row-top").innerHTML = makeLoop(topProducts)
                    .map(renderCard)
                    .join("");
                document.getElementById("featured-row-bottom").innerHTML = makeLoop(bottomProducts)
                    .map(renderCard)
                    .join("");
            }

            function renderProducts(filtered = products) {
                const grid = document.getElementById("products-grid");
                grid.innerHTML = filtered
                    .map(
                        (p, index) => `
        <a href="/product?id=1" class="product-card group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-emerald-800 hover:shadow-xl" style="animation-delay: ${index * 45}ms">
            <div class="overflow-hidden bg-slate-100 aspect-[4/3]">
                <img src="${p.image}" alt="${p.name}" loading="lazy" decoding="async" class="product-image h-full w-full object-cover">
            </div>
            <div class="p-5">
                <div class="mb-3 flex items-center justify-between gap-3">
                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-800">${p.category}</span>
                    <span class="text-xs font-bold text-amber-600">Cód. ${p.code}</span>
                </div>
                <h4 class="text-lg font-bold text-slate-950 mb-2">${p.name}</h4>
                <p class="text-sm text-slate-600 mb-5 line-clamp-2">${p.description}</p>
                <span class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-900 px-4 py-3 text-sm font-bold text-white transition-colors group-hover:bg-amber-500 group-hover:text-slate-950">
                    Ver Detalhes
                </span>
            </div>
        </a>
    `,
                    )
                    .join("");

                if (!filtered.length) {
                    grid.innerHTML =
                        '<div class="md:col-span-2 lg:col-span-3 text-center bg-white border border-slate-200 rounded-lg p-8 text-slate-600">Nenhum produto encontrado nesta categoria.</div>';
                }
            }

            function getFilteredProducts() {
                const normalizedQuery = searchQuery.trim().toLowerCase();

                return products.filter((product) => {
                    const matchesCategory =
                        activeCategory === "all" ||
                        product.category === activeCategory;
                    const matchesSearch =
                        !normalizedQuery ||
                        product.name.toLowerCase().includes(normalizedQuery) ||
                        product.code.toLowerCase().includes(normalizedQuery);

                    return matchesCategory && matchesSearch;
                });
            }

            function updateCategoryButtons() {
                document.querySelectorAll(".category-btn").forEach((button) => {
                    const isActive = button.dataset.category === activeCategory;

                    button.classList.toggle("active", isActive);
                    button.classList.toggle("bg-emerald-900", isActive);
                    button.classList.toggle("text-white", isActive);
                    button.classList.toggle("border-2", !isActive);
                    button.classList.toggle("border-emerald-900", !isActive);
                    button.classList.toggle("text-emerald-900", !isActive);
                });
            }

            function applyProductFilters() {
                const grid = document.getElementById("products-grid");

                clearTimeout(filterTransition);
                grid.classList.add("is-filtering");

                filterTransition = window.setTimeout(() => {
                    renderProducts(getFilteredProducts());
                    requestAnimationFrame(() => {
                        grid.classList.remove("is-filtering");
                    });
                }, 180);
            }

            function filterByCategory(cat) {
                activeCategory = cat;
                updateCategoryButtons();
                applyProductFilters();
            }

            window.filterByCategory = filterByCategory;

            function closeQuoteDrawer() {
                document.getElementById("quote-drawer").classList.add("hidden");
            }

            function openWhatsApp() {
                window.open(
                    "https://wa.me/5551984287099?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes.",
                    "_blank",
                );
            }

            function toggleMobileMenu(forceOpen) {
                const menu = document.getElementById("mobile-menu");
                const shouldOpen =
                    typeof forceOpen === "boolean"
                        ? forceOpen
                        : menu.classList.contains("hidden");

                menu.classList.toggle("hidden", !shouldOpen);
            }

            function updateHeaderState() {
                document
                    .getElementById("site-header")
                    .classList.toggle("is-scrolled", window.scrollY > 8);
            }

            window.closeQuoteDrawer = closeQuoteDrawer;
            window.openWhatsApp = openWhatsApp;
            window.toggleMobileMenu = toggleMobileMenu;

            document
                .getElementById("search-input")
                .addEventListener("input", (e) => {
                    searchQuery = e.target.value;
                    applyProductFilters();
                });

            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") closeQuoteDrawer();
            });

            window.addEventListener("scroll", updateHeaderState, {
                passive: true,
            });

            updateHeaderState();
            renderFeaturedProducts();
            renderProducts();
        </script>
