<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Trends Brindes - Brindes Premium | Porto Alegre RS</title>
        <meta
            name="description"
            content="Brindes premium com gravação laser. Squeeze, garrafas térmicas, mochilas. Entrega rápida RS."
        />
        <meta name="keywords" content="brindes, premium, Porto Alegre" />
        <link rel="icon" type="image/png" href="/logo.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            @tailwind base;
            @tailwind components;
            @tailwind utilities;

            :root {
                --brand: #065f46;
                --brand-hover: #047857;
                --accent: #f59e0b;
                --accent-hover: #d97706;
                --surface: #f8fafc;
                --text: #0f172a;
                --muted: #475569;
                --border: #e2e8f0;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                color: var(--text);
                background:
                    radial-gradient(circle at top left, rgba(245, 158, 11, 0.1), transparent 28rem),
                    var(--surface);
            }

            .section-title {
                font-size: clamp(1.75rem, 4vw, 3rem);
                line-height: 1.08;
                letter-spacing: 0;
            }

            .body-copy {
                font-size: clamp(0.95rem, 1vw, 1.1rem);
            }

            .site-header {
                backdrop-filter: blur(18px);
                background: rgba(255, 255, 255, 0.9);
                transition:
                    box-shadow 180ms ease,
                    border-color 180ms ease;
            }

            .site-header.is-scrolled {
                border-color: rgba(226, 232, 240, 0.95);
                box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
            }

            .fade-up {
                animation: fadeUp 520ms ease both;
            }

            .category-btn {
                background-color: transparent;
                color: #004d3d;
                border: 1px solid #004d3d;
                transition:
                    background-color 180ms ease,
                    color 180ms ease,
                    box-shadow 180ms ease;
            }

            .category-btn:hover {
                background-color: rgba(0, 77, 61, 0.18);
            }

            .category-btn.active {
                background-color: #004d3d;
                color: #ffffff;
                box-shadow: 0 4px 12px rgba(0, 77, 61, 0.2);
            }

            .product-image {
                transition: transform 300ms ease;
            }

            .product-card:hover .product-image {
                transform: scale(1.045);
            }

            #products-grid {
                transition:
                    opacity 220ms ease,
                    transform 220ms ease;
            }

            #products-grid.is-filtering {
                opacity: 0;
                transform: translateY(8px);
            }

            .product-card {
                animation: productFadeIn 320ms ease both;
            }

            .featured-products {
                background:
                    radial-gradient(circle at 10% 20%, rgba(16, 185, 129, 0.05), transparent 30rem),
                    radial-gradient(circle at 90% 80%, rgba(245, 158, 11, 0.05), transparent 30rem),
                    #ffffff;
            }

            .featured-marquee {
                position: relative;
                overflow: hidden;
                -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
                mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
            }

            .featured-marquee + .featured-marquee {
                margin-top: clamp(1.5rem, 3vw, 2.5rem);
            }

            .featured-track {
                display: flex;
                width: max-content;
                gap: clamp(1.5rem, 3vw, 2.5rem);
                will-change: transform;
                transform: translate3d(0, 0, 0);
            }

            .featured-row-right .featured-track {
                animation: featuredScrollRight 35s linear infinite;
            }

            .featured-row-left .featured-track {
                animation: featuredScrollLeft 45s linear infinite;
            }

            .featured-card {
                width: clamp(14rem, 24vw, 22rem);
                flex: 0 0 auto;
                border: 1px solid rgba(15, 23, 42, 0.04);
                border-radius: 1.5rem;
                background: #ffffff;
                padding: 1rem;
                transition:
                    transform 240ms ease,
                    box-shadow 240ms ease;
                shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
            }

            .featured-card:hover,
            .featured-card:focus-visible {
                transform: translateY(-4px);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
            }

            .featured-card-image {
                transition: transform 400ms cubic-bezier(0.2, 0, 0.2, 1);
                filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.03));
            }

            @media (max-width: 640px) {
                .featured-row-right .featured-track {
                    animation-duration: 42s;
                }

                .featured-row-left .featured-track {
                    animation-duration: 54s;
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .featured-row-right .featured-track,
                .featured-row-left .featured-track {
                    animation-duration: 90s;
                }
            }

            @keyframes featuredScrollLeft {
                from {
                    transform: translate3d(0, 0, 0);
                }

                to {
                    transform: translate3d(-50%, 0, 0);
                }
            }

            @keyframes featuredScrollRight {
                from {
                    transform: translate3d(-50%, 0, 0);
                }

                to {
                    transform: translate3d(0, 0, 0);
                }
            }

            @keyframes productFadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(16px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        </style>
    </head>
    <body style="font-family: Plus Jakarta Sans, sans-serif;">
