---
import { products } from "../data/products";
import SpeedInsights from "@vercel/speed-insights/astro";
import CartDrawer from "../components/CartDrawer.astro";
import BaseLayout from "./BaseLayout.astro";

const productsJson = JSON.stringify(products);
---

<BaseLayout
    title="Trends Brindes | Brindes Corporativos Premium"
    description="Brindes corporativos personalizados com aparência premium e atendimento próximo. Garrafas, squeezes, canecas e mais."
    permalink="https://trendsbrindes.com.br"
>
    <main>
        <SpeedInsights />

        <section
            class="relative overflow-hidden bg-emerald-950 text-white px-4"
        >
            <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(245,158,11,0.22),transparent_24rem),radial-gradient(circle_at_85%_10%,rgba(16,185,129,0.18),transparent_22rem)]"
            >
            </div>
            <div
                class="relative max-w-7xl mx-auto py-16 lg:py-20 grid lg:grid-cols-[1.02fr_0.98fr] gap-12 items-center"
            >
                <div class="fade-up">
                    <span
                        class="inline-flex items-center rounded-full border border-emerald-300/25 bg-white/10 px-4 py-2 text-sm font-semibold text-emerald-50"
                    >
                        Brindes corporativos personalizados
                    </span>
                    <h1
                        class="mt-6 font-bold tracking-tight"
                        style="font-size: clamp(2.5rem, 8vw, 5rem); line-height: 0.98;"
                    >
                        Sua marca nas mãos dos seus clientes.
                    </h1>
                    <p
                        class="mt-6 max-w-2xl text-emerald-50"
                        style="font-size: clamp(1rem, 2vw, 1.25rem); line-height: 1.65;"
                    >
                        Brindes corporativos personalizados para empresas,
                        eventos e campanhas promocionais.
                    </p>
                    <div class="mt-8 flex flex-col sm:flex-row gap-3">
                        <a
                            href="https://wa.me/5551984502222?text=Olá!%20Gostaria%20de%20solicitar%20um%20orçamento%20com%20a%20Trends%20Brindes."
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center justify-center rounded-lg bg-amber-500 px-6 py-3 font-bold text-slate-950 shadow-lg shadow-amber-500/20 transition-all hover:-translate-y-0.5 hover:bg-amber-600"
                        >
                            Solicitar Orçamento
                        </a>
                        <a
                            href="#products"
                            class="inline-flex items-center justify-center rounded-lg border border-white/25 bg-white/10 px-6 py-3 font-bold text-white transition-all hover:-translate-y-0.5 hover:bg-white/15"
                        >
                            Ver Catálogo
                        </a>
                    </div>
                    <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div
                            class="rounded-lg border border-white/10 bg-white/10 p-4"
                        >
                            <strong class="block text-2xl text-amber-300"
                                >+500</strong
                            >
                            <span class="text-sm text-emerald-50">produtos</span
                            >
                        </div>
                        <div
                            class="rounded-lg border border-white/10 bg-white/10 p-4"
                        >
                            <strong class="block text-2xl text-amber-300"
                                >Pro</strong
                            >
                            <span class="text-sm text-emerald-50"
                                >personalização</span
                            >
                        </div>
                        <div
                            class="rounded-lg border border-white/10 bg-white/10 p-4"
                        >
                            <strong class="block text-2xl text-amber-300"
                                >RS</strong
                            >
                            <span class="text-sm text-emerald-50"
                                >entrega ágil</span
                            >
                        </div>
                    </div>
                </div>

                <div class="fade-up relative">
                    <div
                        class="absolute -inset-4 rounded-[2rem] bg-amber-400/10 blur-2xl"
                    >
                    </div>
                    <div class="relative grid grid-cols-2 gap-4">
                        <img
                            src="https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=620&h=760&q=80"
                            alt="Garrafa térmica personalizada"
                            class="col-span-1 h-72 sm:h-96 w-full rounded-2xl object-cover shadow-2xl"
                        />
                        <div class="grid gap-4 pt-8">
                            <img
                                src="https://www.guiadosbrindes.com.br/brindes/uploads/produtos/grande/mochilas-e-malas/e@07026-mochila-premium-multifuncional-35-litros-3444717436.webp"
                                alt="Mochila corporativa"
                                class="h-40 sm:h-52 w-full rounded-2xl object-cover shadow-xl"
                            />
                            <div
                                class="rounded-2xl border border-white/10 bg-white/95 p-5 text-slate-900 shadow-xl"
                            >
                                <span
                                    class="text-xs font-bold uppercase tracking-wide text-amber-600"
                                    >Premium</span
                                >
                                <p
                                    class="mt-2 text-sm font-semibold text-slate-700"
                                >
                                    Produtos úteis, bonitos e prontos para levar
                                    sua marca mais longe.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section
            id="featured-products"
            class="featured-products relative overflow-hidden py-16 px-4 md:py-20"
        >
            <div class="absolute inset-x-0 top-8 h-24 bg-amber-300/10 blur-3xl">
            </div>
            <div
                class="absolute bottom-6 right-0 h-36 w-36 rounded-full bg-emerald-700/10 blur-3xl"
            >
            </div>

            <div class="relative mx-auto max-w-7xl">
                <div class="mx-auto max-w-3xl text-center">
                    <span
                        class="text-[11px] font-bold uppercase tracking-[0.2em] text-amber-600/80"
                        >Vitrine</span
                    >
                    <h2 class="section-title mt-3 font-bold text-emerald-950">
                        Produtos em Destaque
                    </h2>
                    <p class="body-copy mt-4 text-slate-500 max-w-xl mx-auto">
                        Conheça alguns dos brindes que ajudam empresas a
                        fortalecer sua marca todos os dias.
                    </p>
                </div>

                <div
                    class="mt-8 md:mt-12"
                    aria-label="Produtos em destaque em movimento contínuo"
                >
                    <div class="featured-marquee featured-row-right">
                        <div id="featured-row-top" class="featured-track"></div>
                    </div>
                    <div class="featured-marquee featured-row-left">
                        <div id="featured-row-bottom" class="featured-track">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="about" class="py-20 px-4 bg-white">
            <div
                class="max-w-7xl mx-auto grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-start"
            >
                <div>
                    <span
                        class="text-sm font-bold uppercase tracking-wide text-amber-600"
                        >Quem Somos</span
                    >
                    <h2 class="section-title mt-3 font-bold text-emerald-950">
                        Brindes com estratégia, acabamento e presença.
                    </h2>
                    <p class="body-copy mt-6 text-slate-600 leading-relaxed">
                        Trabalhamos com soluções criativas e sob medida. Nosso
                        propósito é desenvolver algo diferente de brindes
                        descartáveis: um item útil que permanece, circula e cria
                        conexões diárias.
                    </p>
                </div>
                <div class="grid sm:grid-cols-2 gap-4">
                    <div
                        class="rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm"
                    >
                        <span
                            class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-100 text-emerald-900"
                            >✦</span
                        >
                        <h3 class="font-bold text-slate-950">
                            Personalização Exclusiva
                        </h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Gravação e acabamento pensados para valorizar a
                            identidade da sua marca.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm"
                    >
                        <span
                            class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-100 text-emerald-900"
                            >RS</span
                        >
                        <h3 class="font-bold text-slate-950">Produção Local</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Atendimento próximo e logística rápida para empresas
                            do Rio Grande do Sul.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm"
                    >
                        <span
                            class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-amber-100 text-amber-700"
                            >↗</span
                        >
                        <h3 class="font-bold text-slate-950">Entrega Ágil</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Fluxo comercial objetivo para campanhas, eventos e
                            demandas corporativas.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm"
                    >
                        <span
                            class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-amber-100 text-amber-700"
                            >+</span
                        >
                        <h3 class="font-bold text-slate-950">
                            Grande Variedade
                        </h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Garrafas, canecas, mochilas, bolsas, kits e
                            materiais de escritório.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-20 px-4">
            <div class="max-w-7xl mx-auto">
                <div class="max-w-2xl">
                    <span
                        class="text-sm font-bold uppercase tracking-wide text-amber-600"
                        >Diferenciais</span
                    >
                    <h2 class="section-title mt-3 font-bold text-emerald-950">
                        Por que escolher a Trends?
                    </h2>
                </div>
                <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div
                        class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg"
                    >
                        <h3 class="font-bold text-slate-950">
                            Personalização Profissional
                        </h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Brindes com acabamento comercial e percepção de
                            valor.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg"
                    >
                        <h3 class="font-bold text-slate-950">
                            Atendimento Especializado
                        </h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Curadoria para escolher o produto certo para sua
                            campanha.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg"
                    >
                        <h3 class="font-bold text-slate-950">Produção Local</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Mais proximidade, previsibilidade e agilidade no
                            atendimento.
                        </p>
                    </div>
                    <div
                        class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg"
                    >
                        <h3 class="font-bold text-slate-950">Entrega Ágil</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            Operação preparada para empresas, eventos e ações
                            promocionais.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section id="products" class="py-20 px-4 bg-white">
            <div class="max-w-7xl mx-auto">
                <div class="mx-auto max-w-3xl text-center">
                    <span
                        class="text-sm font-bold uppercase tracking-wide text-amber-600"
                        >Catálogo</span
                    >
                    <h2 class="section-title mt-3 font-bold text-emerald-950">
                        Produtos para campanhas que precisam ser lembradas.
                    </h2>
                    <p class="body-copy mt-4 text-slate-600">
                        Busque por nome ou código e filtre por categoria para
                        encontrar o brinde ideal.
                    </p>
                </div>

                <div class="mt-10 mb-6 flex justify-center">
                    <label class="relative w-full max-w-xl">
                        <span
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"
                            >⌕</span
                        >
                        <input
                            type="text"
                            id="search-input"
                            placeholder="Buscar por nome ou código..."
                            class="w-full rounded-xl border border-slate-200 bg-slate-50 py-4 pl-11 pr-4 text-slate-900 outline-none transition-all placeholder:text-slate-400 focus:border-amber-500 focus:bg-white focus:ring-4 focus:ring-amber-500/10"
                            aria-label="Buscar produtos por nome ou código"
                        />
                    </label>
                </div>

                <div class="-mx-4 mb-10 overflow-x-auto px-4 pb-2">
                    <div
                        class="flex min-w-max gap-2 md:min-w-0 md:flex-wrap md:justify-center"
                    >
                        <button
                            onclick="filterByCategory('all')"
                            class="category-btn active px-4 py-2.5 rounded-full bg-emerald-900 text-white font-bold"
                            data-category="all">Todos</button
                        >
                        <button
                            onclick="filterByCategory('Garrafas e Squeezes')"
                            class="category-btn px-4 py-2.5 rounded-full border-2 border-emerald-900 text-emerald-900 font-semibold"
                            data-category="Garrafas e Squeezes"
                            >Garrafas e Squeezes</button
                        >
                        <button
                            onclick="filterByCategory('Copos e Canecas')"
                            class="category-btn px-4 py-2.5 rounded-full border-2 border-emerald-900 text-emerald-900 font-semibold"
                            data-category="Copos e Canecas"
                            >Copos e Canecas</button
                        >
                        <button
                            onclick="filterByCategory('Bolsas e Mochilas')"
                            class="category-btn px-4 py-2.5 rounded-full border-2 border-emerald-900 text-emerald-900 font-semibold"
                            data-category="Bolsas e Mochilas"
                            >Bolsas e Mochilas</button
                        >
                        <button
                            onclick="filterByCategory('Bolsas Térmicas e Marmitas')"
                            class="category-btn px-4 py-2.5 rounded-full border-2 border-emerald-900 text-emerald-900 font-semibold"
                            data-category="Bolsas Térmicas e Marmitas"
                            >Bolsas Térmicas e Marmitas</button
                        >
                        <button
                            onclick="filterByCategory('Materiais de Escritório')"
                            class="category-btn px-4 py-2.5 rounded-full border-2 border-emerald-900 text-emerald-900 font-semibold"
                            data-category="Materiais de Escritório"
                            >Materiais de Escritório</button
                        >
                    </div>
                </div>

                <div
                    id="products-grid"
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                </div>
            </div>
        </section>

        <section class="py-20 px-4">
            <div class="max-w-7xl mx-auto">
                <div
                    class="grid lg:grid-cols-[0.8fr_1.2fr] gap-10 items-center"
                >
                    <div>
                        <span
                            class="text-sm font-bold uppercase tracking-wide text-amber-600"
                            >Prova social</span
                        >
                        <h2
                            class="section-title mt-3 font-bold text-emerald-950"
                        >
                            Empresas que confiam na Trends
                        </h2>
                        <p
                            class="body-copy mt-4 text-slate-600 leading-relaxed"
                        >
                            Projetos corporativos com curadoria de produtos,
                            atendimento próximo e foco em entrega profissional.
                        </p>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        <div
                            class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm"
                        >
                            <strong class="block text-2xl text-emerald-900"
                                >+500</strong
                            >
                            <span class="text-xs font-semibold text-slate-500"
                                >produtos</span
                            >
                        </div>
                        <div
                            class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm"
                        >
                            <strong class="block text-2xl text-emerald-900"
                                >+100</strong
                            >
                            <span class="text-xs font-semibold text-slate-500"
                                >projetos</span
                            >
                        </div>
                        <div
                            class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm"
                        >
                            <strong class="block text-2xl text-emerald-900"
                                >B2B</strong
                            >
                            <span class="text-xs font-semibold text-slate-500"
                                >atendimento</span
                            >
                        </div>
                        <div
                            class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm"
                        >
                            <strong class="block text-2xl text-emerald-900"
                                >RS</strong
                            >
                            <span class="text-xs font-semibold text-slate-500"
                                >entrega</span
                            >
                        </div>
                    </div>
                </div>
                <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div
                        class="rounded-xl border border-dashed border-slate-300 bg-white/70 p-6 text-center font-bold text-slate-400"
                    >
                        Empresa Parceira
                    </div>
                    <div
                        class="rounded-xl border border-dashed border-slate-300 bg-white/70 p-6 text-center font-bold text-slate-400"
                    >
                        Cliente Corporate
                    </div>
                    <div
                        class="rounded-xl border border-dashed border-slate-300 bg-white/70 p-6 text-center font-bold text-slate-400"
                    >
                        Evento RS
                    </div>
                    <div
                        class="rounded-xl border border-dashed border-slate-300 bg-white/70 p-6 text-center font-bold text-slate-400"
                    >
                        Campanha B2B
                    </div>
                </div>
            </div>
        </section>

        <div
            id="quote-drawer"
            class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden"
            onclick="if(event.target===this) closeQuoteDrawer()"
        >
            <div
                class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-xl flex flex-col"
            >
                <div
                    class="p-6 border-b border-slate-200 flex justify-between items-center"
                >
                    <h2 class="text-2xl font-bold text-emerald-900">
                        Informações de Contato
                    </h2>
                    <button onclick="closeQuoteDrawer()" class="text-2xl"
                        >&times;</button
                    >
                </div>
                <div class="flex-1 overflow-y-auto p-6">
                    <h3 class="font-bold text-emerald-900 mb-4">
                        Entre em contato via WhatsApp
                    </h3>
                    <p class="text-slate-700 mb-6">
                        Clique no botão abaixo para conversar com nosso
                        atendimento no WhatsApp e tirar todas as suas dúvidas!
                    </p>
                </div>
                <div class="p-6 border-t border-slate-200">
                    <button
                        class="w-full bg-green-500 hover:bg-green-600 text-white py-3 rounded-lg font-bold flex items-center justify-center gap-2"
                        onclick="openWhatsApp()">💬 WhatsApp</button
                    >
                </div>
            </div>
        </div>
        <a
            href="https://wa.me/5551984502222?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes."
            target="_blank"
            rel="noopener noreferrer"
            id="whatsapp-btn"
            class="fixed
        bottom-[90px] right-6 flex items-center justify-center transition-all z-30
        hover:scale-110"
            aria-label="Conversar via WhatsApp"
            title="Fale conosco no WhatsApp"
        >
            <img src="/whatsapp.png" alt="WhatsApp" class="w-14 h-14" />
        </a>

        <CartDrawer />

        <script define:vars={{ productsJson }} is:inline>
            window.__PRODUCTS__ = JSON.parse(productsJson);
        </script>

        <script>
            const products = window.__PRODUCTS__;

            let activeCategory = "all";
            let searchQuery = "";
            let filterTransition: ReturnType<typeof setTimeout> | undefined;

            // Cache dos botões — evita querySelectorAll a cada filtragem
            const _categoryButtons = Array.from(
                document.querySelectorAll<HTMLButtonElement>(".category-btn"),
            );
            let _activeCategoryBtn: HTMLButtonElement | null =
                _categoryButtons.find((b) => b.dataset.category === "all") ??
                null;

            function renderFeaturedProducts() {
                const selectedProducts = products.slice(0, 10);
                const topProducts = selectedProducts.slice(0, 5);
                const bottomProducts = selectedProducts.slice(5);
                const makeLoop = (items) => [...items, ...items];
                const renderCard = (product) => `
                <a href="/product?id=${product.id}" class="featured-card group block w-56 max-w-full overflow-hidden focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/25" aria-label="Ver detalhes de ${product.name}">
                    <div class="aspect-square overflow-hidden flex items-center justify-center p-4 bg-slate-50/50 rounded-t-xl">
                        <img
                            src="${product.image}"
                            alt="${product.name}"
                            loading="lazy"
                            decoding="async"
                            class="featured-card-image max-h-32 max-w-full object-contain transition-transform duration-500 group-hover:scale-[1.03]"
                        />
                    </div>
                    <div class="px-3 pb-4 pt-3 text-center">
                        <h3 class="text-sm font-semibold tracking-tight text-slate-800 line-clamp-1">${product.name}</h3>
                        <p class="mt-1 text-[11px] font-medium text-slate-400 uppercase tracking-wider">${product.category}</p>
                    </div>
                </a>
                `;

                document.getElementById("featured-row-top").innerHTML =
                    makeLoop(topProducts).map(renderCard).join("");
                document.getElementById("featured-row-bottom").innerHTML =
                    makeLoop(bottomProducts).map(renderCard).join("");
            }

            function renderProducts(filtered = products) {
                const grid = document.getElementById("products-grid");
                grid.innerHTML = filtered
                    .map(
                        (p, index) => `
                        <a href="/produto/${p.slug}" class="product-card group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-emerald-800 hover:shadow-xl" style="animation-delay: ${index * 45}ms">
                            <div class="overflow-hidden bg-slate-100 aspect-[4/3]">
                                <img src="${p.image}" alt="${p.name}" loading="lazy" decoding="async" class="product-image h-full w-full object-cover">
                            </div>
                            <div class="p-5">
                                <div class="mb-3 flex items-center justify-between gap-3">
                                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-800">${p.category}</span>
                                    <span class="text-xs font-bold text-amber-600">Cód. ${p.code}</span>
                                </div>
                                <h4 class="text-lg font-bold text-slate-950 mb-2">${p.name}</h4>
                                <p class="text-sm text-slate-600 mb-5 line-clamp-2">${p.description}</p>
                                <span class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-900 px-4 py-3 text-sm font-bold text-white transition-colors group-hover:bg-amber-500 group-hover:text-slate-950">
                                    Ver Detalhes
                                </span>
                            </div>
                        </a>
                    `,
                    )
                    .join("");

                if (!filtered.length) {
                    grid.innerHTML =
                        '<div class="md:col-span-2 lg:col-span-3 text-center bg-white border border-slate-200 rounded-lg p-8 text-slate-600">Nenhum produto encontrado nesta categoria.</div>';
                }
            }

            function getFilteredProducts() {
                const normalizedQuery = searchQuery.trim().toLowerCase();
                return products.filter((product) => {
                    const matchesCategory =
                        activeCategory === "all" ||
                        product.category === activeCategory;
                    const matchesSearch =
                        !normalizedQuery ||
                        product.name.toLowerCase().includes(normalizedQuery) ||
                        product.code.toLowerCase().includes(normalizedQuery);
                    return matchesCategory && matchesSearch;
                });
            }

            function updateCategoryButtons() {
                // Remove estado ativo apenas do botão anteriormente ativo
                if (_activeCategoryBtn) {
                    _activeCategoryBtn.classList.remove(
                        "active",
                        "bg-emerald-900",
                        "text-white",
                    );
                    _activeCategoryBtn.classList.add(
                        "border-2",
                        "border-emerald-900",
                        "text-emerald-900",
                    );
                }
                // Aplica estado ativo apenas no novo botão
                _activeCategoryBtn =
                    _categoryButtons.find(
                        (b) => b.dataset.category === activeCategory,
                    ) ?? null;
                if (_activeCategoryBtn) {
                    _activeCategoryBtn.classList.add(
                        "active",
                        "bg-emerald-900",
                        "text-white",
                    );
                    _activeCategoryBtn.classList.remove(
                        "border-2",
                        "border-emerald-900",
                        "text-emerald-900",
                    );
                }
            }

            function applyProductFilters() {
                const grid = document.getElementById("products-grid");
                clearTimeout(filterTransition);
                grid.classList.add("is-filtering");
                filterTransition = window.setTimeout(() => {
                    renderProducts(getFilteredProducts());
                    requestAnimationFrame(() => {
                        grid.classList.remove("is-filtering");
                    });
                }, 180);
            }

            function filterByCategory(cat) {
                activeCategory = cat;
                updateCategoryButtons();
                applyProductFilters();
            }

            window.filterByCategory = filterByCategory;

            function closeQuoteDrawer() {
                document.getElementById("quote-drawer").classList.add("hidden");
            }

            function openWhatsApp() {
                window.open(
                    "https://wa.me/5551984287099?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes.",
                    "_blank",
                );
            }

            window.closeQuoteDrawer = closeQuoteDrawer;
            window.openWhatsApp = openWhatsApp;

            let _searchDebounceTimer = undefined;
            const SEARCH_DEBOUNCE_MS = 220;

            const searchInputEl = document.getElementById(
                "search-input",
            ) as HTMLInputElement;
            searchInputEl?.addEventListener("input", (e) => {
                searchQuery = (e.target as HTMLInputElement).value;
                clearTimeout(_searchDebounceTimer);
                _searchDebounceTimer = window.setTimeout(() => {
                    applyProductFilters();
                }, SEARCH_DEBOUNCE_MS);
            });

            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") closeQuoteDrawer();
            });

            renderFeaturedProducts();
            renderProducts();
        </script>
    </main>
</BaseLayout>

