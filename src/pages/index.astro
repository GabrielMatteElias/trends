---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trends Brindes - Brindes Premium | Porto Alegre RS</title>
    <meta name="description" content="Brindes premium com gravação laser. Squeeze, garrafas térmicas, mochilas. Entrega rápida RS.">
    <meta name="keywords" content="brindes, premium, Porto Alegre">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-900" style="font-family: 'Plus Jakarta Sans', sans-serif;">

<div class="bg-emerald-900 text-white py-2 px-4 text-center text-sm font-medium">
    🌾 ORGULHO DE SER GAÚCHA: PRODUÇÃO E LOGÍSTICA RÁPIDA PARA TODO O RIO GRANDE DO SUL 🌾
</div>

<header class="bg-white border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-emerald-900">Trends Brindes</h1>
        <button id="cart-btn" class="fixed bottom-8 right-8 bg-red-700 hover:bg-red-800 text-white rounded-full w-14 h-14 flex items-center justify-center font-bold text-lg shadow-lg transition-all z-30" aria-label="Abrir sacola">
            <span id="cart-count" class="bg-amber-400 text-emerald-900 rounded-full w-7 h-7 flex items-center justify-center text-sm font-bold absolute -top-2 -right-2">0</span>
            🛒
        </button>
    </div>
</header>

<section class="bg-gradient-to-br from-emerald-900 to-emerald-700 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-5xl font-bold mb-6">A tendência de elevar sua marca para outro patamar.</h2>
        <p class="text-xl text-emerald-100 mb-8">Valorize seus colaboradores, clientes e parceiros com brindes premium que contam histórias.</p>
    </div>
</section>

<section id="about" class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
        <h3 class="text-3xl font-bold text-emerald-900 mb-6">Quem Somos</h3>
        <p class="text-lg text-slate-700 leading-relaxed">Trabalhamos com soluções criativas e sob medida. Nosso propósito é desenvolver algo diferente de brindes descartáveis: um item útil que permanece, circula e cria conexões diárias.</p>
    </div>
</section>

<section id="products" class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
        <h3 class="text-3xl font-bold text-emerald-900 mb-8 text-center">Catálogo de Produtos Premium</h3>
        
        <div class="mb-8 flex gap-4 flex-wrap justify-center">
            <input type="text" id="search-input" placeholder="Buscar por nome ou código..." class="px-4 py-2 border border-slate-300 rounded-lg w-full max-w-sm">
        </div>

        <div class="flex gap-2 flex-wrap justify-center mb-8">
            <button onclick="filterByCategory('all')" class="category-btn active px-4 py-2 rounded-lg bg-emerald-900 text-white font-bold" data-category="all">Todos</button>
            <button onclick="filterByCategory('Bebidas & Térmicos')" class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900" data-category="Bebidas & Térmicos">Bebidas & Térmicos</button>
            <button onclick="filterByCategory('Copos & Canecas')" class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900" data-category="Copos & Canecas">Copos & Canecas</button>
            <button onclick="filterByCategory('Escritório')" class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900" data-category="Escritório">Escritório</button>
            <button onclick="filterByCategory('Bolsas & Sacolas')" class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900" data-category="Bolsas & Sacolas">Bolsas & Sacolas</button>
            <button onclick="filterByCategory('Linha Regional Gaúcha')" class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900" data-category="Linha Regional Gaúcha">Regional Gaúcha</button>
        </div>

        <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        </div>
    </div>
</section>

<div id="quote-drawer" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden" onclick="if(event.target===this) closeQuoteDrawer()">
    <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-xl flex flex-col">
        <div class="p-6 border-b border-slate-200 flex justify-between items-center">
            <h2 class="text-2xl font-bold text-emerald-900">Sua Sacola</h2>
            <button onclick="closeQuoteDrawer()" class="text-2xl">&times;</button>
        </div>
        <div id="quote-items" class="flex-1 overflow-y-auto p-6">
        </div>
        <div class="p-6 border-t border-slate-200">
            <button class="w-full bg-red-700 hover:bg-red-800 text-white py-3 rounded-lg font-bold" onclick="sendWhatsAppQuote()">Enviar via WhatsApp</button>
        </div>
    </div>
</div>

<script>
const products = [
  {
    id: 1,
    code: "9139A",
    name: "Squeeze Alumínio 500ml",
    image: "https://images.unsplash.com/photo-1523362628745-0c100150b504?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 2,
    code: "18821",
    name: "Squeeze Inox 750ml",
    image: "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 3,
    code: "19032",
    name: "Garrafa Térmica Premium 800ml",
    image: "https://images.unsplash.com/photo-1610824352934-c10d87b700cc?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 4,
    code: "18969",
    name: "Copo Térmico Flex 900ml",
    image: "https://images.unsplash.com/photo-1514228742587-6b1558fcf93a?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 5,
    code: "188178",
    name: "Caneca Térmica Max 1.2L",
    image: "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 6,
    code: "CUIA-001",
    name: "Cuia Térmica em Inox Gaúcha",
    image: "https://images.unsplash.com/photo-1594631252845-29fc4cc8cde9?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 7,
    code: "06099A",
    name: "Agenda Diária 2026 Linho Luxo",
    image: "https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 8,
    code: "10998",
    name: "Kit Executivo Premium 3 Peças",
    image: "https://images.unsplash.com/photo-1455390582262-044cdead277a?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 9,
    code: "1329P",
    name: "Bolsa Térmica Oxford 7L",
    image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=400&h=300&q=80"
  },
  {
    id: 10,
    code: "14185",
    name: "Mochila Antifurto Inteligente 16L",
    image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&w=400&h=300&q=80"
  }
];

let quoteCart = JSON.parse(localStorage.getItem('quoteCart')) || [];

function renderProducts(filtered = products) {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = filtered.map(p => `
        <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-all p-4 border border-slate-200">
            <img src="${p.image}" alt="${p.name}" loading="lazy" decoding="async" class="w-full h-48 object-cover rounded-md mb-4">
            <span class="text-xs text-amber-600 font-bold">Cód. ${p.code}</span>
            <h4 class="text-lg font-bold text-slate-900 mb-2">${p.name}</h4>
            <p class="text-sm text-slate-600 mb-3">${p.description}</p>
            <p class="text-xs text-slate-500 mb-4">📏 ${p.size}</p>
            <button onclick="addToQuote(${p.id})" class="w-full bg-red-700 hover:bg-red-800 text-white py-2 rounded-lg font-bold">Adicionar ao Orçamento</button>
        </div>
    `).join('');
}

function filterByCategory(cat) {
    document.querySelectorAll('.category-btn').forEach(b => {
        b.classList.remove('bg-emerald-900', 'text-white');
        b.classList.add('border-2', 'border-emerald-900', 'text-emerald-900');
    });
    event.target.classList.add('bg-emerald-900', 'text-white');
    event.target.classList.remove('border-2', 'border-emerald-900', 'text-emerald-900');
    const filtered = cat === 'all' ? products : products.filter(p => p.category === cat);
    renderProducts(filtered);
}

function addToQuote(id) {
    const product = products.find(p => p.id === id);
    const existing = quoteCart.find(i => i.id === id);
    if (existing) {
        existing.qty++;
    } else {
        quoteCart.push({...product, qty: 1});
    }
    localStorage.setItem('quoteCart', JSON.stringify(quoteCart));
    updateCartUI();
}

function updateQty(id, newQty) {
    const item = quoteCart.find(i => i.id === id);
    if (item) {
        item.qty = Math.max(1, parseInt(newQty) || 1);
        localStorage.setItem('quoteCart', JSON.stringify(quoteCart));
        updateCartUI();
    }
}

function removeFromQuote(id) {
    quoteCart = quoteCart.filter(i => i.id !== id);
    localStorage.setItem('quoteCart', JSON.stringify(quoteCart));
    updateCartUI();
}

function updateCartUI() {
    const total = quoteCart.reduce((sum, i) => sum + i.qty, 0);
    document.getElementById('cart-count').textContent = total;
    
    const items = document.getElementById('quote-items');
    if (quoteCart.length === 0) {
        items.innerHTML = '<p class="text-slate-500">Nenhum item ainda</p>';
    } else {
        items.innerHTML = quoteCart.map(i => `
            <div class="bg-slate-50 p-4 rounded-lg mb-4 border border-slate-200">
                <p class="font-bold text-slate-900">${i.name}</p>
                <p class="text-sm text-slate-600 mb-3">Cód. ${i.code}</p>
                <div class="flex gap-2 items-center">
                    <button onclick="updateQty(${i.id}, ${i.qty - 1})" class="bg-slate-300 px-2 py-1 rounded">−</button>
                    <span class="w-8 text-center">${i.qty}</span>
                    <button onclick="updateQty(${i.id}, ${i.qty + 1})" class="bg-slate-300 px-2 py-1 rounded">+</button>
                    <button onclick="removeFromQuote(${i.id})" class="ml-auto text-red-600 text-sm font-bold">Remover</button>
                </div>
            </div>
        `).join('');
    }
}

function closeQuoteDrawer() {
    document.getElementById('quote-drawer').classList.add('hidden');
}

function sendWhatsAppQuote() {
    if (quoteCart.length === 0) {
        alert('Carrinho vazio');
        return;
    }
    const text = `Olá! Gostaria de solicitar orçamento:\n\n${quoteCart.map(i => `• ${i.name} (${i.code}) - ${i.qty}x`).join('\n')}\n\nObrigado!`;
    const phone = '5151999830908';
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(text)}`);
}

document.getElementById('search-input').addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    const filtered = products.filter(p => 
        p.name.toLowerCase().includes(query) || 
        p.code.toLowerCase().includes(query)
    );
    renderProducts(filtered);
});

document.getElementById('cart-btn').addEventListener('click', () => {
    document.getElementById('quote-drawer').classList.remove('hidden');
});

document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeQuoteDrawer();
});

renderProducts();
updateCartUI();
</script>

</body>
</html>
