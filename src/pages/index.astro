<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Trends Brindes - Brindes Premium | Porto Alegre RS</title>
        <meta
            name="description"
            content="Brindes premium com gravação laser. Squeeze, garrafas térmicas, mochilas. Entrega rápida RS."
        />
        <meta name="keywords" content="brindes, premium, Porto Alegre" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            @tailwind base;
            @tailwind components;
            @tailwind utilities;

            .category-btn {
                transition:
                    background-color 180ms ease,
                    border-color 180ms ease,
                    color 180ms ease,
                    box-shadow 180ms ease,
                    transform 180ms ease;
            }

            .category-btn:hover {
                box-shadow: 0 10px 24px rgba(6, 78, 59, 0.18);
                transform: translateY(-2px);
            }

            .category-btn.active {
                box-shadow: 0 12px 28px rgba(6, 78, 59, 0.2);
            }

            #products-grid {
                transition:
                    opacity 220ms ease,
                    transform 220ms ease;
            }

            #products-grid.is-filtering {
                opacity: 0;
                transform: translateY(8px);
            }

            .product-card {
                animation: productFadeIn 320ms ease both;
            }

            @keyframes productFadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        </style>
    </head>
    <body
        class="bg-slate-50 text-slate-900"
        style="font-family: 'Plus Jakarta Sans', sans-serif;"
    >
        <div
            class="bg-emerald-900 text-white py-2 px-4 text-center text-sm font-medium"
        >
            🌾 ORGULHO DE SER GAÚCHA: PRODUÇÃO E LOGÍSTICA RÁPIDA PARA TODO O
            RIO GRANDE DO SUL 🌾
        </div>

        <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
            <div
                class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center"
            >
                <h1 class="text-2xl font-bold text-emerald-900">
                    Trends Brindes
                </h1>
            </div>
        </header>

        <section
            class="bg-gradient-to-br from-emerald-900 to-emerald-700 text-white py-20 px-4"
        >
            <div class="max-w-4xl mx-auto text-center">
                <h2 class="text-5xl font-bold mb-6">
                    A tendência de elevar sua marca para outro patamar.
                </h2>
                <p class="text-xl text-emerald-100 mb-8">
                    Valorize seus colaboradores, clientes e parceiros com
                    brindes premium que contam histórias.
                </p>
            </div>
        </section>

        <section id="about" class="py-16 px-4 bg-white">
            <div class="max-w-4xl mx-auto">
                <h3 class="text-3xl font-bold text-emerald-900 mb-6">
                    Quem Somos
                </h3>
                <p class="text-lg text-slate-700 leading-relaxed">
                    Trabalhamos com soluções criativas e sob medida. Nosso
                    propósito é desenvolver algo diferente de brindes
                    descartáveis: um item útil que permanece, circula e cria
                    conexões diárias.
                </p>
            </div>
        </section>

        <section id="products" class="py-16 px-4">
            <div class="max-w-7xl mx-auto">
                <h3
                    class="text-3xl font-bold text-emerald-900 mb-8 text-center"
                >
                    Catálogo de Produtos
                </h3>

                <div class="mb-8 flex gap-4 flex-wrap justify-center">
                    <input
                        type="text"
                        id="search-input"
                        placeholder="Buscar por nome ou código..."
                        class="px-4 py-2 border border-slate-300 rounded-lg w-full max-w-sm"
                    />
                </div>

                <div class="flex gap-2 flex-wrap justify-center mb-8">
                    <button
                        onclick="filterByCategory('all')"
                        class="category-btn active px-4 py-2 rounded-lg bg-emerald-900 text-white font-bold"
                        data-category="all">Todos</button
                    >
                    <button
                        onclick="filterByCategory('Garrafas e Squeezes')"
                        class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900"
                        data-category="Garrafas e Squeezes"
                        >Garrafas e Squeezes</button
                    >
                    <button
                        onclick="filterByCategory('Copos e Canecas')"
                        class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900"
                        data-category="Copos e Canecas">Copos e Canecas</button
                    >
                    <button
                        onclick="filterByCategory('Bolsas e Mochilas')"
                        class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900"
                        data-category="Bolsas e Mochilas"
                        >Bolsas e Mochilas</button
                    >
                    <button
                        onclick="filterByCategory('Bolsas Térmicas e Marmitas')"
                        class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900"
                        data-category="Bolsas Térmicas e Marmitas"
                        >Bolsas Térmicas e Marmitas</button
                    >
                    <button
                        onclick="filterByCategory('Materiais de Escritório')"
                        class="category-btn px-4 py-2 rounded-lg border-2 border-emerald-900 text-emerald-900"
                        data-category="Materiais de Escritório"
                        >Materiais de Escritório</button
                    >
                </div>

                <div
                    id="products-grid"
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                </div>
            </div>
        </section>

        <div
            id="quote-drawer"
            class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden"
            onclick="if(event.target===this) closeQuoteDrawer()"
        >
            <div
                class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-xl flex flex-col"
            >
                <div
                    class="p-6 border-b border-slate-200 flex justify-between items-center"
                >
                    <h2 class="text-2xl font-bold text-emerald-900">
                        Informações de Contato
                    </h2>
                    <button onclick="closeQuoteDrawer()" class="text-2xl"
                        >&times;</button
                    >
                </div>
                <div class="flex-1 overflow-y-auto p-6">
                    <h3 class="font-bold text-emerald-900 mb-4">
                        Entre em contato via WhatsApp
                    </h3>
                    <p class="text-slate-700 mb-6">
                        Clique no botão abaixo para conversar com nosso
                        atendimento no WhatsApp e tirar todas as suas dúvidas!
                    </p>
                </div>
                <div class="p-6 border-t border-slate-200">
                    <button
                        class="w-full bg-green-500 hover:bg-green-600 text-white py-3 rounded-lg font-bold flex items-center justify-center gap-2"
                        onclick="openWhatsApp()">💬 WhatsApp</button
                    >
                </div>
            </div>
        </div>

        <a
            href="https://wa.me/5551984502907?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes."
            target="_blank"
            rel="noopener noreferrer"
            id="whatsapp-btn"
            class="fixed bottom-8 right-8 flex items-center justify-center transition-all z-30 hover:scale-110"
            aria-label="Conversar via WhatsApp"
            title="Fale conosco no WhatsApp"
        >
            <img src="/whatsapp.png" alt="WhatsApp" class="w-14 h-14" />
        </a>

        <script>
            const products = [
