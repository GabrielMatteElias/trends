---
// src/pages/404.astro
import Layout from "./BaseLayout.astro";
---

<Layout
    title="Página não encontrada | Axium"
    description="A página que você procura não foi encontrada."
>
    <section class="hero">
        <div class="content">
            <h1>
                Esta página
                <span>não existe.</span>
            </h1>

            <p>
                O link pode estar incorreto ou o conteúdo foi removido. Mas você
                ainda pode conhecer nossos produtos personalizados.
            </p>

            <div class="actions">
                <a href="/catalogo" class="btn primary"> Ver catálogo </a>

                <a
                    href="https://wa.me/5551984287099"
                    target="_blank"
                    rel="noopener"
                    class="btn secondary"
                >
                    Solicitar orçamento
                </a>
            </div>
        </div>

        <div class="illustration">
            <div class="number">404</div>

            <div class="card">
                <h3>Enquanto isso...</h3>

                <ul>
                    <li>✓ Copos térmicos personalizados</li>
                    <li>✓ Garrafas e squeezes</li>
                    <li>✓ Brindes corporativos</li>
                    <li>✓ Gravação a laser permanente</li>
                </ul>
            </div>
        </div>
    </section>
</Layout>

<style>
    :root {
        --primary: #c89b3c;
        --background: #ffffff;
        --card: #ffffff;
        --border: #e5e7eb;
        --text: #111827;
        --muted: #6b7280;
    }

    .hero {
        position: relative;
        overflow: hidden;

        min-height: 100vh;

        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
        align-items: center;

        gap: 6rem;

        padding: 5rem 8%;
        background: var(--background);
    }

    .content {
        position: relative;
        z-index: 2;
    }

    h1 {
        margin: 1.8rem 0 1.5rem;

        font-size: clamp(3.5rem, 8vw, 6.5rem);
        line-height: 0.95;
        color: var(--text);
    }

    h1 span {
        display: block;
        color: var(--primary);
    }

    p {
        max-width: 580px;

        font-size: 1.15rem;
        line-height: 1.8;

        color: var(--muted);
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;

        margin: 3rem 0;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;

        min-width: 190px;

        padding: 1rem 1.8rem;

        border-radius: 12px;

        font-weight: 600;

        text-decoration: none;

        transition: 0.25s;
    }

    .primary {
        background: var(--primary);
        color: #111;
    }

    .primary:hover {
        transform: translateY(-3px);
    }

    .secondary {
        border: 1px solid #d1d5db;
        color: #111827;
        background: #ffffff;
    }

    .secondary:hover {
        background: #f9fafb;
    }

    .illustration {
        display: grid;
        justify-items: center;
        gap: 2rem;
    }

    .number {
        font-size: min(32vw, 15rem);
        line-height: 1;
        font-weight: 900;

        color: transparent;
        -webkit-text-stroke: 2px #d1d5db;
    }

    .card {
        width: min(420px, 100%);

        padding: 2rem;

        border-radius: 20px;

        background: #ffffff;

        border: 1px solid var(--border);

        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.08),
            0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .card h3 {
        margin-bottom: 1.4rem;
        color: var(--text);
    }

    .card ul {
        display: grid;
        gap: 1rem;

        list-style: none;
        padding: 0;
        margin: 0;

        color: var(--muted);
    }

    @media (max-width: 768px) {
        .hero {
            text-align: center;
            padding: 3rem 1.5rem;
            gap: 4rem;
        }

        .actions {
            justify-content: center;
        }
    }
</style>
