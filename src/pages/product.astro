<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Trends Brindes - Detalhes do Produto</title>
        <meta
            name="description"
            content="Veja os detalhes completos do produto"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            @tailwind base;
            @tailwind components;
            @tailwind utilities;

            :root {
                --brand: #065f46;
                --brand-hover: #047857;
                --accent: #f59e0b;
                --surface: #f8fafc;
                --text: #0f172a;
                --muted: #475569;
                --border: #e2e8f0;
            }

            body {
                color: var(--text);
                background:
                    radial-gradient(circle at top left, rgba(245, 158, 11, 0.1), transparent 28rem),
                    var(--surface);
            }

            .site-header {
                backdrop-filter: blur(18px);
                background: rgba(255, 255, 255, 0.9);
                transition:
                    box-shadow 180ms ease,
                    border-color 180ms ease;
            }

            .site-header.is-scrolled {
                border-color: rgba(226, 232, 240, 0.95);
                box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
            }

            .product-gallery img {
                transition: transform 300ms ease;
            }

            .product-gallery:hover img {
                transform: scale(1.025);
            }

            .color-option {
                transition:
                    transform 160ms ease,
                    box-shadow 160ms ease,
                    border-color 160ms ease;
            }

            .color-option:hover,
            .color-option.is-selected {
                transform: scale(1.08);
            }
        </style>
    </head>
    <body style="font-family: 'Plus Jakarta Sans', sans-serif;">
        <div
            class="bg-emerald-950 text-white py-3 px-4 text-center text-sm font-semibold tracking-wide"
        >
            🌾 ORGULHO DE SER GAÚCHA: PRODUÇÃO E LOGÍSTICA RÁPIDA PARA TODO O
            RIO GRANDE DO SUL 🌾
        </div>

        <header id="site-header" class="site-header border-b border-transparent sticky top-0 z-40">
            <div
                class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center"
            >
                <a href="/" class="text-2xl font-bold text-emerald-900 tracking-tight">
                    <img src="/logo-trends.png" alt="Trends Brindes Logo" class="h-12 w-auto" />
                </a>
                <nav class="hidden sm:flex items-center gap-6 text-sm font-semibold text-slate-700">
                    <a href="/#products" class="hover:text-emerald-800 transition-colors">Catálogo</a>
                </nav>
            </div>
        </header>

        <section id="product-section" class="py-14 md:py-20 px-4">
            <div class="max-w-6xl mx-auto">
                <a href="/" class="mb-8 inline-flex items-center text-sm font-bold text-emerald-800 transition-colors hover:text-amber-600">
                    ← Voltar para o catálogo
                </a>
                <div
                    id="product-container"
                    class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-start"
                >
                    <!-- Loading state -->
                    <div class="col-span-2 text-center py-20">
                        <p class="text-lg text-slate-600">
                            Carregando produto...
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <a
            href="https://wa.me/5551984502907?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes."
            target="_blank"
            rel="noopener noreferrer"
            id="whatsapp-btn"
            class="fixed bottom-8 right-8 flex items-center justify-center transition-all z-30 hover:scale-110"
            aria-label="Conversar via WhatsApp"
            title="Fale conosco no WhatsApp"
        >
            <img src="/whatsapp.png" alt="WhatsApp" class="w-14 h-14" />
        </a>

        <script>
