---
import CartDrawer from "../components/CartDrawer.astro";
import { products } from "../data/products";
import SpeedInsights from "@vercel/speed-insights/astro";
import BaseLayout from "./BaseLayout.astro";

const productsJson = JSON.stringify(products);
---

<style>
    body {
        color: var(--text);
        background:
            radial-gradient(
                circle at top left,
                rgba(245, 158, 11, 0.1),
                transparent 28rem
            ),
            var(--surface);
    }

    .color-option {
        transition:
            transform 160ms ease,
            box-shadow 160ms ease,
            border-color 160ms ease;
    }

    .color-option:hover,
    .color-option.is-selected {
        transform: scale(1.08);
    }
</style>
<BaseLayout
    title="Detalhes do Produto"
    description="Veja os detalhes completos do produto"
    permalink="https://trendsbrindes.com.br"
>
    <main >
        <SpeedInsights />

        <div
            class="bg-emerald-950 text-white py-3 px-4 text-center text-sm font-semibold tracking-wide"
        >
            🌾 ORGULHO DE SER GAÚCHA: PRODUÇÃO E LOGÍSTICA RÁPIDA PARA TODO O
            RIO GRANDE DO SUL 🌾
        </div>

        <header
            id="site-header"
            class="site-header border-b border-transparent sticky top-0 z-40"
        >
            <div
                class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center"
            >
                <a
                    href="/"
                    class="text-2xl font-bold text-emerald-900 tracking-tight"
                >
                    <img
                        src="/logo-trends.png"
                        alt="Trends Brindes Logo"
                        class="h-12 w-auto"
                    />
                </a>
                <nav
                    class="hidden sm:flex items-center gap-6 text-sm font-semibold text-slate-700"
                >
                    <a
                        href="/#products"
                        class="hover:text-emerald-800 transition-colors"
                        >Catálogo</a
                    >
                </nav>
            </div>
        </header>

        <section id="product-section" class="py-14 md:py-20 px-4">
            <div class="max-w-6xl mx-auto">
                <a
                    href="/"
                    class="mb-8 inline-flex items-center text-sm font-bold text-emerald-800 transition-colors hover:text-amber-600"
                >
                    ← Voltar para o catálogo
                </a>
                <div
                    id="product-container"
                    class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-start"
                >
                    <div class="col-span-2 text-center py-20">
                        <p class="text-lg text-slate-600">
                            Carregando produto...
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <a
            href="https://wa.me/5551984502907?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20seus%20brindes."
            target="_blank"
            rel="noopener noreferrer"
            id="whatsapp-btn"
            class="fixed bottom-[90px] right-6 flex items-center justify-center transition-all z-30 hover:scale-110"
            aria-label="Conversar via WhatsApp"
            title="Fale conosco no WhatsApp"
        >
            <img src="/whatsapp.png" alt="WhatsApp" class="w-14 h-14" />
        </a>

        <script define:vars={{ productsJson }} is:inline>
            window.__PRODUCTS__ = JSON.parse(productsJson);
        </script>
        <script>
            import { addToCart } from "../scripts/cartStore";

            const products = window.__PRODUCTS__;

            function getProductIdFromURL() {
                const params = new URLSearchParams(window.location.search);
                return parseInt(params.get("id")) || 1;
            }

            function renderProduct() {
                const productId = getProductIdFromURL();
                const product = products.find((p) => p.id === productId);
                const container = document.getElementById("product-container");

                if (!product) {
                    container.innerHTML = `
                <div class="col-span-2 text-center py-20">
                    <h2 class="text-3xl font-bold text-red-600 mb-4">Produto não encontrado</h2>
                    <p class="text-lg text-slate-700 mb-8">Desculpe, o produto que você está procurando não existe.</p>
                    <a href="/" class="inline-block bg-emerald-900 hover:bg-emerald-800 text-white py-3 px-8 rounded-lg font-bold transition-all">
                        ← Voltar para Catálogo
                    </a>
                </div>
            `;
                    return;
                }

                const colorButtons = product.colors
                    .map(
                        (color, index) => `
            <button
                onclick="changeColor(${index})"
                style="background-color: ${color.hex}"
                title="${color.name}"
                aria-label="Selecionar cor ${color.name}"
                class="color-option h-14 w-14 rounded-xl border-2 shadow-sm focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/20 ${index === 0 ? "is-selected border-amber-500 ring-4 ring-amber-500/15" : "border-slate-200"}"
            ></button>
        `,
                    )
                    .join("");

                const productData = JSON.stringify({
                    id: product.id,
                    nome: product.name,
                    codigo: product.code,
                    imagem: product.colors[0].image,
                    categoria: product.category,
                });

                container.innerHTML = `
            <div class="space-y-6">
                <div class="product-gallery overflow-hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-xl shadow-slate-200/70">
                    <img
                        id="main-image"
                        src="${product.colors[0].image}"
                        alt="${product.name}"
                        class="h-[22rem] w-full rounded-xl bg-slate-50 object-contain sm:h-[30rem]"
                    />
                    <p class="mt-4 text-center text-sm font-medium text-slate-500">
                        Clique nas cores para trocar a imagem
                    </p>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                    <h3 class="mb-4 text-lg font-bold text-slate-950">
                        Cores Disponíveis
                    </h3>
                    <div id="colors-container" class="flex flex-wrap gap-4">
                        ${colorButtons}
                    </div>
                </div>
            </div>

            <div>
                <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/70 md:p-8">
                    <h1 class="font-bold text-slate-950 mb-6" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05;">
                        ${product.name}
                    </h1>

                    <div class="mb-6">
                        <span class="inline-flex rounded-full bg-amber-50 px-4 py-2 text-sm font-bold text-amber-700 mb-4">
                            Código: ${product.code}
                        </span>
                        <p class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-lg leading-relaxed text-slate-700">
                            ${product.description}
                        </p>
                    </div>

                    <div class="mb-8 rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
                        <h3 class="mb-2 text-sm font-bold uppercase tracking-wide text-emerald-700">
                            Disponibilidade
                        </h3>
                        <p class="text-lg font-bold text-emerald-950">
                            ${product.availability}
                        </p>
                    </div>

                    <div class="mb-8">
                        <h3 class="font-semibold text-slate-900 mb-2">
                            Categoria
                        </h3>
                        <span class="inline-block rounded-full bg-emerald-50 px-4 py-2 text-sm font-bold text-emerald-800">
                            ${product.category}
                        </span>
                    </div>

                    <button
                        id="add-to-cart-detail"
                        data-product='${productData}'
                        class="flex w-full items-center justify-center gap-3 rounded-xl bg-[#065F46] py-4 text-lg font-bold text-white shadow-lg shadow-emerald-900/20 transition-all hover:-translate-y-0.5 hover:bg-[#047857] active:scale-[0.98] outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#065F46]"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                        <span class="btn-label">Adicionar ao Carrinho</span>
                    </button>
                </div>
            </div>
        `;

                document
                    .getElementById("add-to-cart-detail")
                    ?.addEventListener("click", (e) => {
                        const btn = e.currentTarget as HTMLButtonElement;

                        // Monta o objeto com a cor atualmente selecionada, sem JSON.parse do data-attribute
                        const selectedColor =
                            window.currentProduct?.colors[_selectedColorIndex];
                        const data = {
                            id: window.currentProduct.id,
                            nome: window.currentProduct.name,
                            codigo: window.currentProduct.code,
                            categoria: window.currentProduct.category,
                            imagem:
                                selectedColor?.image ??
                                window.currentProduct.image,
                        };
                        addToCart(data);

                        const label =
                            btn.querySelector<HTMLElement>(".btn-label");
                        if (label) {
                            const original = label.textContent!;
                            label.textContent = "Adicionado!";
                            btn.disabled = true;
                            setTimeout(() => {
                                label.textContent = original;
                                btn.disabled = false;
                            }, 2000);
                        }
                    });

                window.currentProduct = product;
            }

            let _selectedColorIndex = 0;

            window.changeColor = function (index) {
                if (
                    !window.currentProduct ||
                    !window.currentProduct.colors[index]
                )
                    return;

                _selectedColorIndex = index;
                const newImage = window.currentProduct.colors[index].image;

                const mainImage = document.getElementById(
                    "main-image",
                ) as HTMLImageElement;
                if (mainImage) mainImage.src = newImage;

                // Atualiza os botões de cor (lógica idêntica ao original)
                const colorButtons =
                    document.querySelectorAll<HTMLButtonElement>(
                        "#colors-container button",
                    );
                colorButtons.forEach((btn, i) => {
                    if (i === index) {
                        btn.classList.remove("border-slate-200");
                        btn.classList.add(
                            "is-selected",
                            "border-amber-500",
                            "ring-4",
                            "ring-amber-500/15",
                        );
                    } else {
                        btn.classList.remove(
                            "is-selected",
                            "border-amber-500",
                            "ring-4",
                            "ring-amber-500/15",
                        );
                        btn.classList.add("border-slate-200");
                    }
                });
            };

            const siteHeader = document.getElementById("site-header");
            let _rafScrollPending = false;

            function updateHeaderState() {
                if (_rafScrollPending) return;
                _rafScrollPending = true;
                requestAnimationFrame(() => {
                    siteHeader?.classList.toggle(
                        "is-scrolled",
                        window.scrollY > 8,
                    );
                    _rafScrollPending = false;
                });
            }

            window.addEventListener("scroll", updateHeaderState, {
                passive: true,
            });

            updateHeaderState();
            renderProduct();
        </script>

        <CartDrawer />
    </main>
</BaseLayout>
