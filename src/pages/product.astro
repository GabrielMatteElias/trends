            function getProductIdFromURL() {
                const params = new URLSearchParams(window.location.search);
                return parseInt(params.get("id")) || 1;
            }

            function renderProduct() {
                const productId = getProductIdFromURL();
                const product = products.find((p) => p.id === productId);
                const container = document.getElementById("product-container");

                if (!product) {
                    container.innerHTML = `
                        <div class="col-span-2 text-center py-20">
                            <h2 class="text-3xl font-bold text-red-600 mb-4">Produto não encontrado</h2>
                            <p class="text-lg text-slate-700 mb-8">Desculpe, o produto que você está procurando não existe.</p>
                            <a href="/" class="inline-block bg-emerald-900 hover:bg-emerald-800 text-white py-3 px-8 rounded-lg font-bold transition-all">
                                ← Voltar para Catálogo
                            </a>
                        </div>
                    `;
                    return;
                }

                const colorButtons = product.colors
                    .map(
                        (color, index) => `
                    <button
                        onclick="changeColor(${index})"
                        style="background-color: ${color.hex}"
                        title="${color.name}"
                        class="w-16 h-16 rounded-lg border-2 transition-all hover:scale-110 ${index === 0 ? "border-emerald-900 shadow-md" : "border-slate-300"}"
                    />
                `,
                    )
                    .join("");

                const whatsappMessage = `Olá! Tenho interesse no produto: *${product.name}* (${product.code}). Gostaria de mais informações.`;
                const whatsappLink = `https://wa.me/5551984287099?text=${encodeURIComponent(whatsappMessage)}`;

                container.innerHTML = `
                    <div>
                        <div class="bg-white rounded-lg shadow-md p-6 mb-8">
                            <img
                                id="main-image"
                                src="${product.colors[0].image}"
                                alt="${product.name}"
                                class="w-full h-96 object-contain rounded-lg mb-4"
                            />
                            <p class="text-sm text-slate-600 text-center">
                                Clique nas cores para trocar a imagem
                            </p>
                        </div>

                        <div class="bg-white rounded-lg shadow-md p-6">
                            <h3 class="font-bold text-lg mb-4 text-slate-900">
                                Cores Disponíveis
                            </h3>
                            <div id="colors-container" class="flex flex-wrap gap-4">
                                ${colorButtons}
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="bg-white rounded-lg shadow-md p-8">
                            <h1 class="text-3xl font-bold text-slate-900 mb-4">
                                ${product.name}
                            </h1>

                            <div class="mb-6">
                                <span class="text-xs text-amber-600 font-bold block mb-3">
                                    Código: ${product.code}
                                </span>
                                <p class="text-slate-700 text-lg leading-relaxed mb-6">
                                    ${product.description}
                                </p>
                            </div>

                            <div class="mb-8 p-4 bg-blue-50 rounded-lg border border-blue-200">
                                <h3 class="font-semibold text-slate-900 mb-2">
                                    Disponibilidade
                                </h3>
                                <p class="text-lg font-bold text-blue-900">
                                    ${product.availability}
                                </p>
                            </div>

                            <div class="mb-8">
                                <h3 class="font-semibold text-slate-900 mb-2">
                                    Categoria
                                </h3>
                                <span class="inline-block bg-emerald-100 text-emerald-800 text-sm font-semibold px-4 py-2 rounded-full">
                                    ${product.category}
                                </span>
                            </div>

                            <a
                                href="${whatsappLink}"
                                target="_blank"
                                class="w-full bg-green-500 hover:bg-green-600 text-white py-4 rounded-lg font-bold text-lg flex items-center justify-center gap-3 transition-all"
                            >
                                            <img src="/whatsapp.png" alt="WhatsApp" class="w-6 h-6" />
                            Solicitar Informações via WhatsApp
                            </a>

                            <a
                                href="/"
                                class="mt-6 block w-full bg-slate-200 hover:bg-slate-300 text-slate-900 py-3 rounded-lg font-bold text-center transition-all"
                            >
                                ← Voltar para Catálogo
                            </a>
                        </div>
                    </div>
                `;

                window.currentProduct = product;
            }

            window.changeColor = function (index) {
                if (
                    !window.currentProduct ||
                    !window.currentProduct.colors[index]
                )
                    return;

                const mainImage = document.getElementById("main-image");
                mainImage.src = window.currentProduct.colors[index].image;

                const buttons = document.querySelectorAll(
                    "#colors-container button",
                );
                buttons.forEach((btn, i) => {
                    if (i === index) {
                        btn.classList.remove("border-slate-300");
                        btn.classList.add("border-emerald-900", "shadow-md");
                    } else {
                        btn.classList.remove("border-emerald-900", "shadow-md");
                        btn.classList.add("border-slate-300");
                    }
                });
            };

            renderProduct();
        </script>
