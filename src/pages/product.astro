                    availability: "Em estoque",
                    colors: [
                        { name: "Preto", hex: "#000000", image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=600&h=500&q=80" },
                        { name: "Cinza", hex: "#808080", image: "https://images.unsplash.com/photo-1514228742587-6b1558fcf93a?auto=format&fit=crop&w=600&h=500&q=80" },
                        { name: "Vermelho", hex: "#DC143C", image: "https://images.unsplash.com/photo-1510307704987-b8f5070fc64d?auto=format&fit=crop&w=600&h=500&q=80" },
                    ]
                },
                {
                    id: 10,
                    code: "14185",
                    name: "Mochila Antifurto Inteligente 16L",
                    category: "Bolsas e Mochilas",
                    description:
                        "Mochila com capacidade 16L, recursos antifurto e compartimentos organizados. Perfeita para trabalho, viagens ou uso diário.",
                    image: "https://www.cdncloud.com.br/content/interfaces/cms/userfiles/pacotes_xbzbrindes/pack_202407181828472162/fotos003/mochila-de-nylon-17-litros-3427.jpg",
                    availability: "Em estoque",
                    colors: [
                        { name: "Preto", hex: "#000000", image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&w=600&h=500&q=80" },
                        { name: "Cinza", hex: "#808080", image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=600&h=500&q=80" },
                        { name: "Azul", hex: "#0066CC", image: "https://images.unsplash.com/photo-1514228742587-6b1558fcf93a?auto=format&fit=crop&w=600&h=500&q=80" },
                    ]
                },
            ];

            function getProductIdFromURL() {
                const params = new URLSearchParams(window.location.search);
                return parseInt(params.get("id")) || 1;
            }

            function renderProduct() {
                const productId = getProductIdFromURL();
                const product = products.find((p) => p.id === productId);
                const container = document.getElementById("product-container");

                if (!product) {
                    container.innerHTML = `
                        <div class="col-span-2 text-center py-20">
                            <h2 class="text-3xl font-bold text-red-600 mb-4">Produto não encontrado</h2>
                            <p class="text-lg text-slate-700 mb-8">Desculpe, o produto que você está procurando não existe.</p>
                            <a href="/" class="inline-block bg-emerald-900 hover:bg-emerald-800 text-white py-3 px-8 rounded-lg font-bold transition-all">
                                ← Voltar para Catálogo
                            </a>
                        </div>
                    `;
                    return;
                }

                const colorButtons = product.colors
                    .map(
                        (color, index) => `
                    <button
                        onclick="changeColor(${index})"
                        style="background-color: ${color.hex}"
                        title="${color.name}"
                        aria-label="Selecionar cor ${color.name}"
                        class="color-option h-14 w-14 rounded-xl border-2 shadow-sm focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/20 ${index === 0 ? "is-selected border-amber-500 ring-4 ring-amber-500/15" : "border-slate-200"}"
                    ></button>
                `,
                    )
                    .join("");

                const whatsappMessage = `Olá! Tenho interesse no produto: *${product.name}* (${product.code}). Gostaria de mais informações.`;
                const whatsappLink = `https://wa.me/5551984287099?text=${encodeURIComponent(whatsappMessage)}`;

                container.innerHTML = `
                    <div class="space-y-6">
                        <div class="product-gallery overflow-hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-xl shadow-slate-200/70">
                            <img
                                id="main-image"
                                src="${product.colors[0].image}"
                                alt="${product.name}"
                                class="h-[22rem] w-full rounded-xl bg-slate-50 object-contain sm:h-[30rem]"
                            />
                            <p class="mt-4 text-center text-sm font-medium text-slate-500">
                                Clique nas cores para trocar a imagem
                            </p>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                            <h3 class="mb-4 text-lg font-bold text-slate-950">
                                Cores Disponíveis
                            </h3>
                            <div id="colors-container" class="flex flex-wrap gap-4">
                                ${colorButtons}
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/70 md:p-8">
                            <h1 class="font-bold text-slate-950 mb-6" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05;">
                                ${product.name}
                            </h1>

                            <div class="mb-6">
                                <span class="inline-flex rounded-full bg-amber-50 px-4 py-2 text-sm font-bold text-amber-700 mb-4">
                                    Código: ${product.code}
                                </span>
                                <p class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-lg leading-relaxed text-slate-700">
                                    ${product.description}
                                </p>
                            </div>

                            <div class="mb-8 rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
                                <h3 class="mb-2 text-sm font-bold uppercase tracking-wide text-emerald-700">
                                    Disponibilidade
                                </h3>
                                <p class="text-lg font-bold text-emerald-950">
                                    ${product.availability}
                                </p>
                            </div>

                            <div class="mb-8">
                                <h3 class="font-semibold text-slate-900 mb-2">
                                    Categoria
                                </h3>
                                <span class="inline-block rounded-full bg-emerald-50 px-4 py-2 text-sm font-bold text-emerald-800">
                                    ${product.category}
                                </span>
                            </div>

                            <a
                                href="${whatsappLink}"
                                target="_blank"
                                class="flex w-full items-center justify-center gap-3 rounded-xl bg-amber-500 py-4 text-lg font-bold text-slate-950 shadow-lg shadow-amber-500/20 transition-all hover:-translate-y-0.5 hover:bg-amber-600"
                            >
                                            <img src="/whatsapp.png" alt="WhatsApp" class="h-6 w-6" />
                            Solicitar Informações via WhatsApp
                            </a>
                        </div>
                    </div>
                `;

                window.currentProduct = product;
            }

            window.changeColor = function (index) {
                if (
                    !window.currentProduct ||
                    !window.currentProduct.colors[index]
                )
                    return;

                const mainImage = document.getElementById("main-image");
                mainImage.src = window.currentProduct.colors[index].image;

                const buttons = document.querySelectorAll(
                    "#colors-container button",
                );
                buttons.forEach((btn, i) => {
                    if (i === index) {
                        btn.classList.remove("border-slate-200");
                        btn.classList.add(
                            "is-selected",
                            "border-amber-500",
                            "ring-4",
                            "ring-amber-500/15",
                        );
                    } else {
                        btn.classList.remove(
                            "is-selected",
                            "border-amber-500",
                            "ring-4",
                            "ring-amber-500/15",
                        );
                        btn.classList.add("border-slate-200");
                    }
                });
            };

            function updateHeaderState() {
                document
                    .getElementById("site-header")
                    .classList.toggle("is-scrolled", window.scrollY > 8);
            }

            window.addEventListener("scroll", updateHeaderState, {
                passive: true,
            });

            updateHeaderState();
            renderProduct();
        </script>
    </body>
</html>
